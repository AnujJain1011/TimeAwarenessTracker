{
  "manifest_version": 3,
  "name": "Where Did My Time Go?",
  "version": "1.0",
  "description": "Tracks time spent on websites and shows productivity insights.",

  "permissions": [
    "tabs",
    "storage",
    "idle"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Where Did My Time Go?"
  }
}
